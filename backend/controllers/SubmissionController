// @route PUT /api/submissions/:id/evaluate
exports.evaluateSubmission = async (req, res) => {
  try {
    const { manualAnswers, feedback } = req.body;
    const submission = await Submission.findById(req.params.id);

    if (!submission) {
      return res.status(404).json({ success: false, message: 'Submission not found' });
    }

    // Calculate auto-graded score
    let autoScore = submission.answers
      .filter(a => a.isCorrect !== null)
      .reduce((acc, a) => acc + (a.isCorrect ? a.points : 0), 0);

    // Apply manual grades
    let manualScore = 0;
    const updatedAnswers = submission.answers.map((answer, idx) => {
      if (answer.isCorrect === null && manualAnswers) {
        const manual = manualAnswers[idx] || manualAnswers.find((_, i) => {
          const nullAnswers = submission.answers.filter(a => a.isCorrect === null);
          return nullAnswers[i] && nullAnswers[i].questionId?.toString() === answer.questionId?.toString();
        });
        if (manual) {
          manualScore += manual.points || 0;
          return { ...answer.toObject(), points: manual.points || 0, feedback: manual.feedback || '' };
        }
      }
      return answer;
    });

    const totalScore = autoScore + manualScore;
    const percentage = Math.round((totalScore / submission.maxScore) * 100);

    const updated = await Submission.findByIdAndUpdate(
      req.params.id,
      {
        status: 'evaluated',
        totalScore,
        percentage,
        instructorFeedback: feedback,
        evaluatedBy: req.user._id,
        evaluatedAt: new Date(),
        answers: updatedAnswers
      },
      { new: true }
    );

    await ActivityLog.create({
      user: req.user.name,
      userId: req.user._id,
      action: 'assessment_evaluated',
      details: `Evaluated submission by ${submission.studentName}`,
      ip: req.ip,
      userAgent: req.headers['user-agent']
    });

    res.json({ success: true, data: updated });
  } catch (error) {
    res.status(500).json({ success: false, message: error.message });
  }
};